{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "gitlab>mcf.io/renovate-config",
    "gitlab>mcf.io/renovate-config//managers/cnpg.json",
    "gitlab>mcf.io/renovate-config//managers/oci.json",
    "gitlab>mcf.io/renovate-config//managers/talos-factory.json",
    "gitlab>mcf.io/renovate-config//managers/grafana-dashboards.json",
    "gitlab>mcf.io/renovate-config//overrides/changelogs.json",
    "gitlab>mcf.io/renovate-config//overrides/helmfile.json"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/\\.ya?ml(?:\\.j2)?$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "repository:\\s*(?<depName>ghcr\\.io/koush/scrypted)",
        "tag:\\s*v?(?<currentValue>\\d+\\.\\d+\\.\\d+)-(?<flavour>[a-zA-Z0-9-_]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "koush/scrypted",
      "autoReplaceStringTemplate": "tag: v{{{newValue}}}-{{{flavour}}}"
    }
  ],
  "packageRules": [
    // Automerge Rules
    {
      "description": "Auto-merge trusted container digests",
      "matchDatasources": ["docker"],
      "automerge": true,
      "automergeType": "pr",
      "matchUpdateTypes": ["digest"],
      "matchPackageNames": ["/home-operations/"],
      "ignoreTests": false
    },
    {
      "description": "Schedule auto-merge for specific oci helm releases",
      "matchDatasources": ["docker"],
      "automerge": true,
      "automergeType": "pr",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchPackageNames": ["/kube-prometheus-stack/"],
      "ignoreTests": false,
      "schedule": ["before 6am on Monday"]
    },
    {
      "description": "Auto-merge gitlab-ci images patch and digests",
      "matchManagers": ["gitlabci"],
      "matchDatasources": ["docker"],
      "automerge": true,
      "automergeType": "pr",
      "matchUpdateTypes": [
        "patch",
        "digest"
      ],
      "ignoreTests": false
    },
    // Groups
    {
      "groupName": "Flux Operator Group",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "/flux-operator/",
        "/flux-instance/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}}"
      },
      "minimumGroupSize": 2
    },
    {
      "groupName": "Rook-Ceph Group",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "/rook-ceph/",
        "/rook-ceph-cluster/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}}"
      },
      "minimumGroupSize": 2
    },
    {
      "groupName": "kubernetes Group",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "/kube-apiserver/",
        "/kube-controller-manager/",
        "/kube-proxy/",
        "/kube-scheduler/",
        "/kubelet/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}}"
      },
      "minimumGroupSize": 5
    },
    // Overrides
    {
      "managerFilePatterns": ["/\\.ya?ml(?:\\.j2)?$/"],
      "matchPackageNames": ["ghcr.io/koush/scrypted"],
      "matchDatasources": ["docker"],
      "enabled": false
    }
  ]
}
