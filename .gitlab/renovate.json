{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "gitlab>mcf.io/renovate-config",
    "gitlab>mcf.io/milton/talos-n150-cluster//.renovate/autoMerge.json5",
    "gitlab>mcf.io/milton/talos-n150-cluster//.renovate/customManagers",
    "gitlab>mcf.io/milton/talos-n150-cluster//.renovate/groups",
    "gitlab>mcf.io/milton/talos-n150-cluster//.renovate/versioning.json5",
    "gitlab>mcf.io/milton/talos-n150-cluster//.renovate/overrides",
    "gitlab>mcf.io/milton/talos-n150-cluster//.renovate/schedules",
    "gitlab>mcf.io/milton/talos-n150-cluster//.renovate/grafanaDashboards.json5"
  ],
  "reviewers": ["nick.mcfaul"],
  "ignorePaths": [
    "**/.archive/**"
  ],
  "flux": {
    "managerFilePatterns": [
      "/\\.yaml(?:\\.j2)?$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/)kubernetes/.+\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml(?:\\.j2)?$/"
    ]
  }
}
