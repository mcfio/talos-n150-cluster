amends "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Builtins.pkl"

local mise_globs = List(
  ".mise/config.toml",
  "**/.mise.toml",
  "**/.mise.*.toml"
)

local ci_prefix = "MISE_ENV=ci mise x --"

local linters = new Mapping<String, Step> {
  ["oxfmt"] = (Builtins.oxfmt) { prefix = ci_prefix }
  ["yamllint"] = (Builtins.yamllint) { prefix = ci_prefix }
  ["pinact"] = (Builtins.pinact) { prefix = ci_prefix }
  ["mise"] = (Builtins.mise) {
    glob = mise_globs
  }
}

local miselock = new Group {
  steps {
    ["mise-lock"] {
      glob = mise_globs
      fix = "mise lock"
      stage = List("mise.lock", "**/mise.lock")
    }
  }
}

local all_steps = new Mapping<String, Step | Group> {
  ["miselock"] = miselock
  ...linters
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = all_steps
  }
  ["fix"] {
    fix = true
    steps = all_steps
  }
  ["check"] {
    steps = linters
  }
}
