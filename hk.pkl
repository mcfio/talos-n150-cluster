amends "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  ["yamlfmt"] = Builtins.yamlfmt
  ["yamllint"] = Builtins.yamllint
  ["mise"] = Builtins.mise
}

local miselock = new Group {
  steps {
    ["mise-lock"] {
      glob = ".mise/config.toml"
      fix = "mise lock"
      stage = ".mise/mise.lock"
    }
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps {
      ["miselock"] = miselock
      ...linters
    }
  }
  ["fix"] {
    fix = true
    steps {
      ["miselock"] = miselock
      ...linters
    }
  }
  ["check"] {
    steps = linters
  }
}
