{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "groupName": "Flux Operator Group",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "/flux-operator/",
        "/flux-instance/",
        "/flux-operator-manifests/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}}"
      },
      "minimumGroupSize": 3
    },
    {
      "groupName": "Intel Device Plugins Group",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "/intel-device-plugins-operator/",
        "/intel-device-plugins-gpu/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}}"
      },
      "minimumGroupSize": 2
    },
    {
      "groupName": "Rook-Ceph Group",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "/rook-ceph/",
        "/rook-ceph-cluster/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}}"
      },
      "minimumGroupSize": 2
    },
    {
      "groupName": "kubernetes Group",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "/kube-apiserver/",
        "/kube-controller-manager/",
        "/kube-proxy/",
        "/kube-scheduler/",
        "/kubelet/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}}"
      },
      "minimumGroupSize": 5
    },
    {
      "groupName": "Talos Linux Group",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "/installer/",
        "/talosctl/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}}"
      },
      "minimumGroupSize": 2
    },
    {
      "groupName": "Actions Runner Controller Group",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "/gha-runner-scale-set-controller/",
        "/gha-runner-scale-set/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}}"
      },
      "minimumGroupSize": 2
    }
  ]
}
